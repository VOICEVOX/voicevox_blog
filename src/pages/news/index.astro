---
/**
 * 記事ディレクトリにある記事一覧を表示するページ。
 * ファイル名の逆順に表示する。
 */

import { withBaseUrl } from "@/helper";
import Base from "@/layouts/Base.astro";
import shareThumb from "./_share.jpg";
import { articles } from "./constants";

// TODO: リリース時にnoindexを外す
---

<Base
  title="ニュース | VOICEVOX"
  description="無料で使えるテキスト読み上げ・歌声合成ソフトウェア、VOICEVOXのニュース一覧です。"
  image={shareThumb}
  imageAlt=""
  noindex={true}
>
  <main class="py-12">
    <div class="mx-auto max-w-5xl px-4">
      <h1 class="mb-6 text-3xl font-bold text-neutral-950">ニュース</h1>
      {
        articles.map((article) => (
          <div class="mb-3">
            <a
              class="text-[rgb(48,100,57)] underline hover:text-[rgb(38,80,47)]"
              href={withBaseUrl(`/news/${article.frontmatter.slug}`)}
            >
              {article.frontmatter.title}
            </a>
            <p class="text-neutral-400">{article.frontmatter.date}</p>
          </div>
        ))
      }
    </div>
  </main>
</Base>
