---
import { withBaseUrl } from "@/helper";
import "@/styles/global.css";
import Button from "@/components/ui/Button/index.astro";

/**
 * ボイボ寮とVOICEVOXをちょっとだけ紹介するコンポーネント
 */

interface Props {
  showingDormitoryPageButton?: boolean;
}

const { showingDormitoryPageButton } = Astro.props;
---

<section class="py-lg">
  <div class="px-xl">
    <div class="mx-auto flex max-w-5xl flex-col bg-white">
      <div class="py-lg flex flex-col items-center text-center">
        <h2 class="mb-xl text-2xl font-bold">ボイボ寮とは</h2>
        <p class="text-base">
          VOICEVOX
          のキャラたちの設定があると動画制作の参考になるかと思って用意した世界観です。
        </p>
        <p class="text-base">
          必ずしも遵守する必要はなく、自由に改変して頂いても問題ありません。
        </p>
        {
          showingDormitoryPageButton && (
            <Button
              href={withBaseUrl("/dormitory/")}
              kind="outline"
              tone="neutral"
              shape="pill"
              size="md"
              class="mt-lg self-center"
            >
              ボイボ寮ページへ
            </Button>
          )
        }
      </div>

      <div class="py-lg flex flex-col items-center text-center">
        <h2 class="mb-xl text-2xl font-bold">VOICEVOX とは</h2>
        <p class="text-base">
          無料で使える中品質なテキスト読み上げソフトウェアです。
        </p>
        <p class="text-base">
          商用・非商用問わず無料で、イントネーションの詳細な調整ができることが特徴です。
        </p>
        <Button
          href={withBaseUrl("/")}
          kind="solid"
          tone="primary"
          shape="pill"
          size="md"
          class="mt-lg self-center"
        >
          ダウンロード
        </Button>
      </div>
    </div>
  </div>
</section>
