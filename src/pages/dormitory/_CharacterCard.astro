---
import type { CharacterInfo } from "@/constants/type";
import { getDormitoryCharacterPageUrl } from "@/constants/url";
import { withBaseUrl } from "@/helper";
import { Image } from "astro:assets";

interface Props {
  characterInfo: CharacterInfo;
  class?: string;
}

const { characterInfo, class: className } = Astro.props;

const color = characterInfo.color || "black";
const href = getDormitoryCharacterPageUrl(characterInfo);
---

<div
  id={characterInfo.id}
  class={"vv-anchor-offset-7 col-span-12 p-3 sm:col-span-6 md:col-span-3 " +
    (className ?? "")}
>
  <div
    class="h-full cursor-pointer rounded-2xl border-[3px] pt-3 shadow-none"
    style={{ borderColor: color }}
  >
    <a href={withBaseUrl(href)}>
      <Image
        class="mx-auto block object-contain"
        src={characterInfo.bustupImage}
        alt={characterInfo.name}
        width={320}
        height={320}
        densities={[1, 1.5, 2]}
      />
      <div
        class="border-t-[2.5px] px-0 py-5 text-center"
        style={{ borderColor: color }}
      >
        <h3 class="text-xl font-semibold">{characterInfo.name}</h3>
      </div>
    </a>
  </div>
</div>
