---
import { dormitoryEvents } from "@/constants/dormitoryEvent";
import { Image } from "astro:assets";

interface Props {
  id: string;
}

const { id } = Astro.props;
---

<div class="mx-auto flex max-w-5xl flex-col items-center bg-white py-12 text-center">
  <h2
    id={id}
    class="pt-[calc(3.25rem+1rem)] -mt-[calc(3.25rem+1rem)] mb-6 text-2xl font-extrabold leading-7 text-neutral-700"
  >
    <a href={`#${id}`} class="text-black"> 過去のイベント </a>
  </h2>
  <div class="grid w-full grid-cols-1 gap-4 px-4 md:grid-cols-3">
    {
      // 過去のイベント
      dormitoryEvents.map((event) => (
        <div>
          <a
            href={`${event.link}`}
            class="text-black"
            target="_blank"
            rel="noreferrer"
          >
            <Image
              src={event.image}
              alt=""
              width={480}
              densities={[1, 1.5, 2]}
              class="block w-full cursor-pointer rounded-2xl border border-black shadow-none"
              style={{ objectFit: "contain" }}
            />
            <p
              class="mt-2 text-base leading-6 text-neutral-950"
              set:html={event.titles.join("<br />")}
            />
          </a>
        </div>
      ))
    }
  </div>
</div>
