---
import FontAwesomeIcon from "@/components/FontAwesomeIcon.astro";
import PlayButton from "@/components/PlayButton/index.astro";
import { characterEntries, characterKeys } from "@/constants/characterEntry";
import { characterInfos } from "@/constants/characterInfo";
import { callNameInfos } from "@/constants/characterInfos/callNameInfo";
import { getProductPageUrl } from "@/constants/url";
import { withBaseUrl } from "@/helper";
import Base from "@/layouts/Base.astro";
import { faHome } from "@fortawesome/free-solid-svg-icons";
import type { GetStaticPaths, InferGetStaticPropsType } from "astro";
import { getImage, Image } from "astro:assets";
import backgroundImage from "../images/nc238325.jpg";
import CallBox from "./_CallBox.astro";
import { descriptionTypes } from "./_constants";
import TypeButton from "./_TypeButton.astro";

export const getStaticPaths = (async () => {
  return characterKeys.flatMap((key) =>
    descriptionTypes.map((d) => ({
      params: {
        characterId: characterEntries[key].id,
        descriptionType: d == "profile" ? undefined : d, // NOTE: 以前に合わせるため、プロフィールページはURLをネストしない
      },
      props: { characterInfo: characterInfos[key], descriptionType: d },
    })),
  );
}) satisfies GetStaticPaths;
type Props = InferGetStaticPropsType<typeof getStaticPaths>;

const { characterInfo, descriptionType } = Astro.props;
const characterKey = characterInfo.key;
const descriptionNames = {
  profile: "プロフィール",
  calls: "呼び方",
} satisfies Record<(typeof descriptionTypes)[number], string>;

const backgroundImageUrl = `url(${(await getImage({ src: backgroundImage })).src})`;
---

<Base
  title={`${characterInfo.name} | ボイボ寮 ${
    descriptionNames[descriptionType]
  } | VOICEVOX`}
  description={characterInfo.description}
  image={characterInfo.dormitoryShareImage}
  imageAlt={characterInfo.dormitoryShareImage ? "" : undefined}
>
  <div
    class="bg-white/70 bg-cover bg-fixed bg-blend-lighten"
    style={{ backgroundImage: backgroundImageUrl }}
  >
    <main class="px-6 py-1 lg:px-12">
      <div
        class="mx-auto flex min-h-screen max-w-3xl flex-col items-center justify-center gap-3 md:min-h-[calc(100vh-52px)] md:max-w-[820px]"
      >
        <div
          class={`w-full overflow-hidden rounded-xl border-solid bg-white md:h-[550px]`}
          style={{ borderColor: characterInfo.color, borderWidth: "3px" }}
          data-testid="dormitory-character-card"
        >
          <div class="flex flex-col md:h-full md:flex-row">
            <div
              class="relative flex items-center justify-center overflow-hidden px-0 max-md:py-1 md:h-full md:w-1/3 md:border-r-[3px]"
              style={{ borderColor: characterInfo.color }}
            >
              <div class="h-screen w-full md:h-full">
                <div class="flex h-full items-center justify-center">
                  <Image
                    src={characterInfo.portraitImage}
                    alt={characterInfo.name}
                    width={640}
                    densities={[1, 1.5, 2]}
                    class="block h-full w-auto max-w-none object-contain"
                  />
                </div>
              </div>
            </div>

            <div
              class={`flex-1 p-6 ${descriptionType === "calls" ? "pb-3" : ""}`}
            >
              <div class="flex h-full flex-col">
                <div class="flex items-start">
                  <h1
                    class="mb-6 text-3xl leading-9 font-extrabold text-neutral-700"
                    set:html={characterInfo.rubyName}
                  />
                  <a
                    class="ml-auto inline-flex h-12 w-12 items-center justify-center rounded-full border-[1.8px] bg-transparent px-0 py-[7px] hover:bg-neutral-50"
                    style={{
                      color: characterInfo.color,
                      borderColor: characterInfo.color,
                      visibility: characterInfo.detailUrl
                        ? "visible"
                        : "hidden",
                    }}
                    href={characterInfo.detailUrl &&
                      withBaseUrl(characterInfo.detailUrl)}
                    aria-label={`${characterInfo.name}の詳細ページ`}
                    target="_blank"
                    rel="noreferrer"
                  >
                    <FontAwesomeIcon icon={faHome} />
                  </a>
                </div>

                <div class="inline-flex max-md:mb-3">
                  <TypeButton
                    characterInfo={characterInfo}
                    selectedType={descriptionType}
                    targetType="profile"
                    targetName={descriptionNames.profile}
                  />
                  <TypeButton
                    characterInfo={characterInfo}
                    selectedType={descriptionType}
                    targetType="calls"
                    targetName={descriptionNames.calls}
                  />
                </div>

                {
                  descriptionType === "profile" && (
                    <>
                      <div
                        class="mt-6 mb-2 text-xl font-bold"
                        set:html={characterInfo.description}
                      />

                      <div class="-mx-1 grid grid-cols-1 gap-0 md:grid-cols-2">
                        {characterInfo.labelInfos.map((labelInfo) => (
                          <div
                            class={labelInfo.size === 1 ? "" : "md:col-span-2"}
                          >
                            <div class="flex items-center px-1 pt-3">
                              <span
                                class="inline-flex w-28 items-center justify-center rounded-lg py-2 text-center text-white"
                                style={{
                                  backgroundColor: characterInfo.color,
                                }}
                              >
                                {labelInfo.label}
                              </span>
                              <span class="grow pl-3 text-base">
                                {labelInfo.value}
                              </span>
                            </div>
                          </div>
                        ))}
                      </div>

                      <div class="-mx-1 flex items-center px-1 pt-3">
                        <span
                          class="inline-flex w-28 items-center justify-center rounded-lg py-2 text-center text-white"
                          style={{ backgroundColor: characterInfo.color }}
                        >
                          音声サンプル
                        </span>
                        {characterInfo.dormitoryVoiceAudios ? (
                          <div class="flex grow flex-wrap gap-1 pl-3">
                            {characterInfo.dormitoryVoiceAudios.map(
                              (audio, index) => (
                                <PlayButton
                                  audio={audio}
                                  name={`${
                                    characterInfo.name
                                  }のサンプルボイス${index + 1}`}
                                  color={characterInfo.color}
                                  class="mr-1"
                                />
                              ),
                            )}
                          </div>
                        ) : (
                          <span class="grow pl-3 text-base">準備中</span>
                        )}
                      </div>

                      {characterInfo.dormitoryImages && (
                        <div class="mt-3 flex max-h-32 gap-0 overflow-hidden">
                          {characterInfo.dormitoryImages.map((image) => (
                            <div class="flex flex-1 items-center justify-center">
                              <Image
                                src={image}
                                alt={characterInfo.name}
                                height={256}
                                densities={[1, 1.5, 2]}
                                class="block h-32 w-full object-contain"
                              />
                            </div>
                          ))}
                        </div>
                      )}
                    </>
                  )
                }

                {
                  descriptionType === "calls" && (
                    <div class="flex flex-1 flex-col gap-0 overflow-hidden pt-3 md:flex-row md:gap-6">
                      <div class="flex flex-row justify-center gap-8 max-md:h-32 md:flex-col">
                        <div class="flex h-26 w-26 flex-none flex-col items-center justify-center rounded-2xl border-2 border-black px-3 text-center">
                          <div class="mb-1 font-bold">
                            <span>一人称</span>
                          </div>
                          <div class="text-sm">
                            {callNameInfos[characterKey].me.map((callName) => (
                              <p>{callName}</p>
                            ))}
                          </div>
                        </div>
                        <div class="flex h-26 w-26 flex-none flex-col items-center justify-center rounded-2xl border-2 border-black px-3 text-center">
                          <div class="mb-1 font-bold">
                            <span>二人称</span>
                          </div>
                          <div class="text-sm">
                            {callNameInfos[characterKey].you.map((callName) => (
                              <p>{callName}</p>
                            ))}
                          </div>
                        </div>
                      </div>
                      <div class="vv-scrollbar-thin flex flex-1 flex-col gap-2 overflow-auto md:pr-1">
                        {characterKeys
                          .filter(
                            (targetCharacterKey) =>
                              targetCharacterKey !== characterKey,
                          )
                          .map((targetCharacterKey) => (
                            <CallBox
                              characterInfo={characterInfo}
                              baseCharacterKey={characterKey}
                              targetCharacterKey={targetCharacterKey}
                            />
                          ))}
                      </div>
                    </div>
                  )
                }
              </div>
            </div>
          </div>
        </div>

        <div class="flex flex-wrap items-center justify-center gap-2 font-bold">
          <a
            href={withBaseUrl(getProductPageUrl(characterInfo))}
            class="inline-flex h-10 items-center justify-center rounded-full border bg-white px-5 hover:bg-neutral-50"
            style={{ borderColor: characterInfo.color, borderWidth: "1.5px" }}
          >
            ダウンロードページ
          </a>
          <a
            href={withBaseUrl(`/dormitory/#${characterInfo.id}`)}
            class="inline-flex h-10 items-center justify-center rounded-full border bg-white px-5 hover:bg-neutral-50"
            style={{ borderColor: characterInfo.color, borderWidth: "1.5px" }}
          >
            キャラクター一覧
          </a>
        </div>
      </div>
    </main>
  </div>
</Base>
