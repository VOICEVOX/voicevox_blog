---
/**
 * 一番上に表示するコンポーネント。
 * PC版ではキャラ名・キャライラスト・キャラメニューがファーストビューに表示される。
 * モバイル版ではキャライラスト・キャラメニューがファーストビューに表示される。
 */

import KeepScrollAnchor from "@/components/KeepScrollAnchor.astro";
import Button from "@/components/ui/Button/index.astro";
import IconButton from "@/components/ui/IconButton/index.astro";
import type { CharacterKey } from "@/constants/characterEntry";
import { characterKeys } from "@/constants/characterEntry";
import { characterInfos } from "@/constants/characterInfo";
import {
  getDormitoryCharacterPageUrl,
  getProductPageUrl,
} from "@/constants/url";
import { withBaseUrl } from "@/helper";
import {
  showDownloadModalAttr,
  showLibraryTermIntroModalCharacterKeyAttr,
} from "@/store";
import {
  faCircleLeft,
  faCircleRight,
  faDownload,
} from "@fortawesome/free-solid-svg-icons";
import { FontAwesomeIcon } from "@fortawesome/react-fontawesome";
import { Image } from "astro:assets";
import AudioSample from "./_AudioSample";
import { buildDescription } from "./constants";

interface Props {
  characterKey: CharacterKey;
}

const { characterKey } = Astro.props;
const characterInfo = characterInfos[characterKey];

const description = buildDescription(characterInfo);
const additionalDescription = characterInfo.additionalProductDescription;
const characterBackgroundColor = characterInfo.lightColor;

const prevCharacterKey =
  characterKeys[
    (characterKeys.indexOf(characterKey) + characterKeys.length - 1) %
      characterKeys.length
  ];
const postCharacterKey =
  characterKeys[
    (characterKeys.indexOf(characterKey) + 1) % characterKeys.length
  ];
---

<div class="@container">
  <div
    class="relative mx-auto grid w-[calc(100%-48px)] max-w-7xl grid-cols-1 grid-rows-[calc(100vh-3.25rem-5rem)_5rem_auto] md:h-[calc(100vh-3.25rem)] md:max-h-[1024px] md:min-h-[512px] md:grid-cols-2 md:grid-rows-[1fr_5rem]"
  >
    <div
      class="max-md:pt-3xl md:px-3xl col-start-1 row-start-3 flex flex-col items-center justify-center px-0 md:col-start-1 md:row-start-1 md:items-start"
    >
      <h1 class="mb-xl text-3xl font-extrabold">
        VOICEVOX {characterInfo.name}
      </h1>
      <p class="text-xl">
        {description}
        {additionalDescription && additionalDescription}
      </p>
      {
        characterInfo.releaseDate == undefined && (
          <Button
            {...{ [showDownloadModalAttr]: "" }}
            kind="solid"
            tone="primary"
            shape="pill"
            size="xl"
            class="mt-xl"
          >
            <span slot="icon">
              <FontAwesomeIcon icon={faDownload} />
            </span>
            <span class="font-semibold">
              <span class="max-lg:hidden">VOICEVOX を </span>
              ダウンロード
            </span>
          </Button>
        )
      }
      <div
        class="mt-xl gap-xs flex flex-col items-center md:flex-row md:flex-wrap md:items-start"
      >
        <Button
          href={withBaseUrl("/term/")}
          kind="outline"
          tone="neutral"
          shape="pill"
          size="md"
        >
          VOICEVOX 利用規約
        </Button>
        {
          characterInfo.policyUrl && (
            <Button
              {...{ [showLibraryTermIntroModalCharacterKeyAttr]: characterKey }}
              kind="outline"
              tone="neutral"
              shape="pill"
              size="md"
            >
              {characterInfo.name} 利用規約
            </Button>
          )
        }
        {
          characterInfo.additionalProductLinks &&
            characterInfo.additionalProductLinks.map((obj) => (
              <Button
                href={obj.url}
                target="_blank"
                rel="noreferrer"
                kind="outline"
                tone="neutral"
                shape="pill"
                size="md"
              >
                {obj.label}
              </Button>
            ))
        }
      </div>
    </div>

    <div class="relative col-start-1 row-start-1 md:col-start-2 md:row-start-1">
      <div
        class="absolute inset-y-0 left-0 w-full md:w-[50cqw]"
        style={{ backgroundColor: characterBackgroundColor }}
      >
      </div>
      <div class="absolute inset-0 flex overflow-hidden">
        <div class="relative left-1/2 flex-none -translate-x-1/2">
          <Image
            class="block h-full w-auto object-contain"
            src={characterInfo.portraitImage}
            alt={characterInfo.name}
            height={1280}
            densities={[1, 1.5, 2]}
          />
        </div>
      </div>
      <div
        class="gap-md pb-lg absolute inset-y-0 right-[5%] flex flex-col justify-end"
      >
        <div
          class="gap-md p-md flex w-50 flex-col items-end rounded-2xl bg-white/80"
        >
          <p>{characterInfo.description.replaceAll("<br />", "")}</p>
          <a
            href={withBaseUrl(getDormitoryCharacterPageUrl(characterInfo))}
            class="vv-link-subtle font-bold text-black">キャラクター詳細 →</a
          >
        </div>

        <AudioSample client:visible characterInfo={characterInfo} />
      </div>
    </div>

    <IconButton
      href={withBaseUrl(getProductPageUrl(characterInfos[prevCharacterKey]))}
      size="md"
      class="absolute top-[10%] left-[calc(50%-50vw+1.2rem)] -translate-y-1/2 text-5xl text-black opacity-25 hover:opacity-40"
      aria-label="前のキャラクターを表示"
    >
      <FontAwesomeIcon icon={faCircleLeft} />
    </IconButton>
    <IconButton
      href={withBaseUrl(getProductPageUrl(characterInfos[postCharacterKey]))}
      size="md"
      class="absolute top-[10%] right-[calc(50%-50vw+1.2rem)] -translate-y-1/2 text-5xl text-black opacity-25 hover:opacity-40"
      aria-label="次のキャラクターを表示"
    >
      <FontAwesomeIcon icon={faCircleRight} />
    </IconButton>

    <div class="col-start-1 row-start-2 h-20 md:col-span-2 md:row-start-2">
      <div
        class="vv-scrollbar-hidden-until-hover flex h-full overflow-x-auto overflow-y-hidden"
        aria-label="キャラクター一覧"
      >
        {
          characterKeys.map((key) => (
            <KeepScrollAnchor
              href={withBaseUrl(getProductPageUrl(characterInfos[key]))}
              aria-current={key === characterKey ? "page" : undefined}
              class:list={[
                "px-xs box-content flex aspect-square flex-none",
                key === characterKey
                  ? "py-md relative h-12 opacity-100"
                  : "py-lg h-10 opacity-50 hover:opacity-80",
              ]}
              aria-label={characterInfos[key].name}
            >
              {key === characterKey && (
                <span
                  class="absolute top-0 left-0 h-1 w-full"
                  style={{ backgroundColor: characterInfos[key].color }}
                />
              )}
              <Image
                class="m-auto h-full w-auto rounded-lg"
                src={characterInfos[key].bustupImage}
                alt={characterInfos[key].name}
                width="64"
                densities={[1, 1.5, 2]}
                style={{ backgroundColor: characterInfos[key].lightColor }}
              />
            </KeepScrollAnchor>
          ))
        }
      </div>
    </div>
  </div>
</div>

<script>
  function scrollToCenter() {
    const characterList = document.querySelector(
      "[aria-label='キャラクター一覧']",
    );
    if (characterList == undefined) return;

    if (!(characterList instanceof HTMLElement))
      throw new Error(`characterList is not HTMLElement: ${characterList}`);

    const active = characterList.querySelector("[aria-current='page']");
    if (!(active instanceof HTMLElement))
      throw new Error(
        `aria-current page element is not HTMLElement: ${active}`,
      );

    const activeCenter = active.offsetLeft + active.offsetWidth / 2;
    const containerCenter = characterList.offsetWidth / 2;
    characterList.scrollLeft = activeCenter - containerCenter;
  }
  document.addEventListener("astro:after-swap", scrollToCenter);

  scrollToCenter();
</script>
