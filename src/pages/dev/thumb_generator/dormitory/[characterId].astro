---
/**
 * ボイボ寮の個別ページのサムネイル生成
 */
import DormitoryCharacterPage, {
  getStaticPaths as baseGetStaticPaths,
} from "@/pages/dormitory/[characterId]/[...descriptionType].astro";
import type { InferGetStaticPropsType } from "astro";

export const getStaticPaths = baseGetStaticPaths;
type Props = InferGetStaticPropsType<typeof getStaticPaths>;
---

<meta charset="utf-8" />
<meta name="robots" content="noindex, nofollow" />

<DormitoryCharacterPage {...Astro.props} descriptionType="profile" />

<style is:global>
  /* 比率を1200:630に */
  [data-testid="dormitory-character-card"] {
    width: 800px !important;
    height: 420px !important;
  }

  /* 名前と紹介文の余白を詰める */
  [data-testid="dormitory-character-card"] h1 {
    margin-bottom: var(--spacing-xs);
  }
  [data-testid="dormitory-character-card"] .mt-xl.mb-xs.text-xl.font-bold {
    margin-top: var(--spacing-xs);
  }

  /* 音声サンプル行を非表示 */
  [data-testid="dormitory-character-card"] .grid + div {
    display: none;
  }

  /* プロフィール・呼び方切替を非表示 */
  [data-testid="dormitory-character-card"] .inline-flex.self-start {
    display: none;
  }

  /* ホームボタンを透明化 */
  [data-testid="dormitory-character-card"] a:has(.fa-house) {
    visibility: hidden;
  }
</style>
