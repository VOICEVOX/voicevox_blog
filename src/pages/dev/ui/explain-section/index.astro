---
import ExplainSection from "@/pages/dormitory/_ExplainSection.astro";
import "@/styles/global.css";
---

<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="robots" content="noindex, nofollow" />
    <title>ExplainSection 確認用ページ</title>
  </head>
  <body>
    <div class="p-2xl">
      <h1 class="mb-xl text-2xl font-bold">ExplainSection 確認用ページ</h1>

      <section class="mb-2xl">
        <h2 class="mb-md text-xl font-semibold">デフォルト</h2>
        <ExplainSection />
      </section>

      <section class="mb-2xl">
        <h2 class="mb-md text-xl font-semibold">
          showingDormitoryPageButton=true
        </h2>
        <ExplainSection showingDormitoryPageButton />
      </section>
    </div>
  </body>
</html>
