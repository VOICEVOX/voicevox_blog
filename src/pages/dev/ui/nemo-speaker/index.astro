---
import SpeakerComponent from "@/pages/nemo/_SpeakerComponent.astro";
import { getSpeakerInfo } from "@/pages/nemo/constants";
import "@/styles/global.css";

const speakerInfos = [
  getSpeakerInfo("nemo_female_002"),
  getSpeakerInfo("nemo_male_001"),
];
---

<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="robots" content="noindex, nofollow" />
    <title>SpeakerComponent (nemo) 確認用ページ</title>
  </head>
  <body class="bg-[rgb(9,10,12)] text-white">
    <div class="p-2xl min-h-screen">
      <h1 class="mb-3xl text-base text-white">
        SpeakerComponent (nemo) 確認用ページ
      </h1>

      <section class="mb-2xl">
        <h2 class="mb-md text-xl font-semibold text-white">デフォルト</h2>
        <div
          class="gap-2xl px-md mx-auto grid w-full max-w-5xl place-content-center max-md:grid-cols-[repeat(1,minmax(0,25rem))] md:grid-cols-2"
        >
          {
            speakerInfos.map((info, i) => (
              <SpeakerComponent
                info={info}
                style={{ zIndex: speakerInfos.length - i }}
              />
            ))
          }
        </div>
      </section>

      <section class="mb-2xl">
        <h2 class="mb-md text-xl font-semibold text-white">
          CVドロップダウン（開いた状態）
        </h2>
        <div class="**:[[role=menu]]:block!">
          <div
            class="gap-2xl px-md mx-auto grid w-full max-w-5xl place-content-center max-md:[grid-template-columns:repeat(1,minmax(0,25rem))] md:grid-cols-2"
          >
            <SpeakerComponent info={speakerInfos[0]} style={{ zIndex: 1 }} />
          </div>
        </div>
      </section>
    </div>
  </body>
</html>
