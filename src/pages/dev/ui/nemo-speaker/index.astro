---
import SpeakerComponent from "@/pages/nemo/_SpeakerComponent.astro";
import { getSpeakerInfo } from "@/pages/nemo/constants";
import "@/styles/global.css";

const speakerInfos = [
  getSpeakerInfo("nemo_female_002"),
  getSpeakerInfo("nemo_male_001"),
];
---

<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="robots" content="noindex, nofollow" />
    <title>SpeakerComponent (nemo) 確認用ページ</title>
  </head>
  <body class="bg-[rgb(9,10,12)] text-white">
    <div class="nemo-speaker-preview" style="padding: 2rem;">
      <h1 class="mb-12 text-base text-white">
        SpeakerComponent (nemo) 確認用ページ
      </h1>

      <section class="mb-8">
        <h2 class="mb-4 text-xl font-semibold text-white">デフォルト</h2>
        <div class="speakers-container mx-auto w-full max-w-5xl px-4">
          {
            speakerInfos.map((info, i) => (
              <SpeakerComponent
                info={info}
                style={{ zIndex: speakerInfos.length - i }}
              />
            ))
          }
        </div>
      </section>

      <section class="mb-8">
        <h2 class="mb-4 text-xl font-semibold text-white">
          CVドロップダウン（開いた状態）
        </h2>
        <div class="dropdown-force-open">
          <div class="speakers-container mx-auto w-full max-w-5xl px-4">
            <SpeakerComponent info={speakerInfos[0]} style={{ zIndex: 1 }} />
          </div>
        </div>
      </section>
    </div>
  </body>
</html>

<style is:global>
  .nemo-speaker-preview {
    min-height: 100vh;
  }

  .speakers-container {
    display: grid;
    gap: 2rem;
    grid-template-columns: repeat(2, 1fr);
    place-content: center;
  }

  @media (max-width: 768px) {
    .speakers-container {
      grid-template-columns: repeat(1, minmax(0, 25rem));
    }
  }

  .dropdown-force-open .group\/dropdown > div:last-child {
    display: block !important;
  }
</style>
