---
import Footer from "@/components/Footer.astro";
import "@/styles/global.css";
---

<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="robots" content="noindex, nofollow" />
    <title>Footer 確認用ページ</title>
  </head>
  <body>
    <div class="p-8">
      <h1 class="mb-6 text-2xl font-bold">Footer 確認用ページ</h1>

      <section class="mb-8">
        <h2 class="mb-4 text-xl font-semibold">デフォルト（isDark=false）</h2>
        <div class="p-4">
          <Footer />
        </div>
      </section>

      <section class="mb-8">
        <h2 class="mb-4 text-xl font-semibold">ダークモード（isDark=true）</h2>
        <div data-theme="dark">
          <div class="bg-black p-4">
            <Footer />
          </div>
        </div>
      </section>
    </div>
  </body>
</html>
