---
import OssGuidanceSection from "@/pages/_OssGuidanceSection.astro";
import "@/styles/global.css";
---

<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="robots" content="noindex, nofollow" />
    <title>OssGuidanceSection 確認用ページ</title>
  </head>
  <body>
    <div class="p-2xl">
      <h1 class="mb-xl text-2xl font-bold">OssGuidanceSection 確認用ページ</h1>

      <section class="mb-2xl">
        <h2 class="mb-md text-xl font-semibold">デフォルト</h2>
        <OssGuidanceSection />
      </section>

      <section class="mb-2xl">
        <h2 class="mb-md text-xl font-semibold">isDark</h2>
        {/* NOTE: `/song` に合わせて isDark の本文色は親側で白にしています。 */}
        <div data-theme="dark" class="bg-black text-white">
          <OssGuidanceSection />
        </div>
      </section>
    </div>
  </body>
</html>
