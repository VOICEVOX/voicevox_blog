---
import { characterInfos } from "@/constants/characterInfo";
import AudioSample from "@/pages/talk/_AudioSample";
import "@/styles/global.css";

const characterInfo = characterInfos["ずんだもん"];

// NOTE: src/pages/talk/_CharacterCard.astro の is:global スタイルを dev/ui でも再現するため、必要最小限を複製しています
---

<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="robots" content="noindex, nofollow" />
    <title>AudioSample (talk) 確認用ページ</title>
  </head>
  <body>
    <div class="p-2xl">
      <h1 class="mb-xl text-2xl font-bold">AudioSample (talk) 確認用ページ</h1>

      <section class="mb-2xl">
        <h2 class="mb-md text-xl font-semibold">音声サンプルUI</h2>
        <div class="px-md mx-auto flex max-w-5xl flex-col">
          <div class="flex justify-center">
            <div
              class="px-xs box-border w-full max-w-none min-[769px]:w-1/2 min-[960px]:w-1/3"
            >
              <div class="p-xl rounded-2xl bg-white shadow-lg">
                <div class="text-center">
                  <h3 class="mb-0 text-2xl font-bold">{characterInfo.name}</h3>
                  <AudioSample
                    client:load
                    audioSamples={characterInfo.talkVoiceAudios}
                    characterName={characterInfo.name}
                  />
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>
    </div>
  </body>
</html>
