---
import { characterInfos } from "@/constants/characterInfo";
import AudioSample from "@/pages/talk/_AudioSample";
import "@/styles/global.css";

const characterInfo = characterInfos["ずんだもん"];
---

<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="robots" content="noindex, nofollow" />
    <title>AudioSample (talk) 確認用ページ</title>
  </head>
  <body>
    <div style="padding: 2rem;">
      <h1 class="text-2xl font-bold mb-6">AudioSample (talk) 確認用ページ</h1>

      <section class="mb-8">
        <h2 class="text-xl font-semibold mb-4">音声サンプルUI</h2>
        <div class="max-w-[960px] mx-auto px-4 flex flex-col">
          <div class="flex justify-center">
            <div
              class="w-full min-[769px]:w-1/2 min-[960px]:w-1/3 max-w-none box-border px-2"
            >
              <div class="rounded-2xl bg-white shadow-lg p-6">
                <div class="text-center">
                  <h3 class="text-2xl font-bold mb-0">{characterInfo.name}</h3>
                  <AudioSample
                    client:load
                    audioSamples={characterInfo.talkVoiceAudios}
                    characterName={characterInfo.name}
                    className=""
                  />
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>
    </div>
  </body>
</html>

<style lang="scss" is:global>
  /* NOTE: src/pages/talk/_CharacterCard.astro の is:global スタイルを dev/ui でも再現するため、必要最小限を複製しています */
</style>
