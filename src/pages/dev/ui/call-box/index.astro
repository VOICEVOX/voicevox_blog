---
import { characterInfos } from "@/constants/characterInfo";
import CallBox from "@/pages/dormitory/[characterId]/_CallBox.astro";
import "@/styles/global.css";

const shikokuMetan = characterInfos.四国めたん;
const zundamon = characterInfos.ずんだもん;

// NOTE: src/pages/dormitory/[characterId]/[...descriptionType].astro の is:global スタイルを dev/ui でも再現するため、必要最小限を複製しています
---

<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="robots" content="noindex, nofollow" />
    <title>CallBox 確認用ページ</title>
  </head>
  <body>
    <div class="p-8">
      <h1 class="mb-6 text-2xl font-bold">CallBox 確認用ページ</h1>

      <section class="mb-8">
        <h2 class="mb-4 text-xl font-semibold">四国めたん → ずんだもん</h2>
        <CallBox
          characterInfo={shikokuMetan}
          baseCharacterKey="四国めたん"
          targetCharacterKey="ずんだもん"
        />
      </section>

      <section class="mb-8">
        <h2 class="mb-4 text-xl font-semibold">四国めたん → 春日部つむぎ</h2>
        <CallBox
          characterInfo={shikokuMetan}
          baseCharacterKey="四国めたん"
          targetCharacterKey="春日部つむぎ"
        />
      </section>

      <section class="mb-8">
        <h2 class="mb-4 text-xl font-semibold">ずんだもん → 雨晴はう</h2>
        <CallBox
          characterInfo={zundamon}
          baseCharacterKey="ずんだもん"
          targetCharacterKey="雨晴はう"
        />
      </section>
    </div>
  </body>
</html>
