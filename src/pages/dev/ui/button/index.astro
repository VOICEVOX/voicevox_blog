---
import FontAwesomeIcon from "@/components/FontAwesomeIcon.astro";
import Button from "@/components/ui/Button/index.astro";
import "@/styles/global.css";
import { faArrowRight, faDownload } from "@fortawesome/free-solid-svg-icons";
import { ReactButtonDemo } from "./_ReactButtonDemo.tsx";
---

<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="robots" content="noindex, nofollow" />
    <title>Button 確認用ページ</title>
  </head>
  <body>
    <div class="p-2xl">
      <h1 class="mb-xl text-2xl font-bold">Button 確認用ページ</h1>

      <section class="mb-2xl">
        <h2 class="mb-md text-xl font-semibold">
          solid / primary / pill（iconなし）
        </h2>
        <div class="gap-md flex flex-wrap items-center">
          <Button kind="solid" tone="primary" shape="pill" size="xs">xs</Button>
          <Button kind="solid" tone="primary" shape="pill" size="sm">sm</Button>
          <Button kind="solid" tone="primary" shape="pill" size="md">md</Button>
          <Button kind="solid" tone="primary" shape="pill" size="lg">lg</Button>
          <Button kind="solid" tone="primary" shape="pill" size="xl">xl</Button>
        </div>
      </section>

      <section class="mb-2xl">
        <h2 class="mb-md text-xl font-semibold">
          solid / primary / pill（start icon）
        </h2>
        <div class="gap-md flex flex-wrap items-center">
          <Button kind="solid" tone="primary" shape="pill" size="xs">
            <span slot="icon"><FontAwesomeIcon icon={faDownload} /></span>
            xs
          </Button>
          <Button kind="solid" tone="primary" shape="pill" size="sm">
            <span slot="icon"><FontAwesomeIcon icon={faDownload} /></span>
            sm
          </Button>
          <Button kind="solid" tone="primary" shape="pill" size="md">
            <span slot="icon"><FontAwesomeIcon icon={faDownload} /></span>
            md
          </Button>
          <Button kind="solid" tone="primary" shape="pill" size="lg">
            <span slot="icon"><FontAwesomeIcon icon={faDownload} /></span>
            lg
          </Button>
          <Button kind="solid" tone="primary" shape="pill" size="xl">
            <span slot="icon"><FontAwesomeIcon icon={faDownload} /></span>
            xl
          </Button>
        </div>
      </section>

      <section class="mb-2xl">
        <h2 class="mb-md text-xl font-semibold">
          outline / neutral / pill（start icon）
        </h2>
        <div class="gap-md flex flex-wrap items-center">
          <Button kind="outline" tone="neutral" shape="pill" size="xs">
            <span slot="icon"><FontAwesomeIcon icon={faArrowRight} /></span>
            xs
          </Button>
          <Button kind="outline" tone="neutral" shape="pill" size="sm">
            <span slot="icon"><FontAwesomeIcon icon={faArrowRight} /></span>
            sm
          </Button>
          <Button kind="outline" tone="neutral" shape="pill" size="md">
            <span slot="icon"><FontAwesomeIcon icon={faArrowRight} /></span>
            md
          </Button>
        </div>
      </section>

      <section class="mb-2xl">
        <h2 class="mb-md text-xl font-semibold">
          outline / neutral / rounded（start icon）
        </h2>
        <div class="gap-md flex flex-wrap items-center">
          <Button kind="outline" tone="neutral" shape="rounded" size="xs">
            <span slot="icon"><FontAwesomeIcon icon={faArrowRight} /></span>
            xs
          </Button>
          <Button kind="outline" tone="neutral" shape="rounded" size="sm">
            <span slot="icon"><FontAwesomeIcon icon={faArrowRight} /></span>
            sm
          </Button>
          <Button kind="outline" tone="neutral" shape="rounded" size="md">
            <span slot="icon"><FontAwesomeIcon icon={faArrowRight} /></span>
            md
          </Button>
        </div>
      </section>

      <section class="mb-2xl">
        <h2 class="mb-md text-xl font-semibold">solid / white / pill</h2>

        <h3 class="mb-sm text-lg font-semibold">ダーク背景</h3>
        <div data-theme="dark" class="p-xl rounded-lg bg-black">
          <div class="gap-md flex flex-wrap items-center">
            <Button kind="solid" tone="white" shape="pill" size="md">md</Button>
            <Button kind="solid" tone="white" shape="pill" size="lg">lg</Button>
            <Button kind="solid" tone="white" shape="pill" size="xl">xl</Button>
            <Button kind="solid" tone="white" shape="pill" size="md">
              <span slot="icon"><FontAwesomeIcon icon={faArrowRight} /></span>
              md
            </Button>
          </div>
        </div>
      </section>

      <section class="mb-2xl">
        <h2 class="mb-md text-xl font-semibold">href あり/なし比較</h2>
        <div class="gap-md flex flex-wrap items-center">
          <Button
            href="https://github.com/VOICEVOX/voicevox"
            target="_blank"
            rel="noreferrer"
            kind="outline"
            tone="neutral"
            shape="pill"
            size="md"
          >
            <span slot="icon"><FontAwesomeIcon icon={faArrowRight} /></span>
            hrefあり
          </Button>
          <Button kind="outline" tone="neutral" shape="pill" size="md">
            <span slot="icon"><FontAwesomeIcon icon={faArrowRight} /></span>
            hrefなし
          </Button>
        </div>
      </section>

      <section class="mb-2xl">
        <h2 class="mb-md text-xl font-semibold">レスポンシブ size 上書き例</h2>
        <div class="gap-md flex flex-wrap items-center">
          <Button
            kind="solid"
            tone="primary"
            shape="pill"
            size="xs"
            class="md:vv-button-size-md lg:vv-button-size-lg"
          >
            <span slot="icon"><FontAwesomeIcon icon={faDownload} /></span>
            Nemo風
          </Button>
        </div>
      </section>

      <section class="mb-2xl">
        <h2 class="mb-md text-xl font-semibold">React</h2>
        <ReactButtonDemo client:load />
      </section>
    </div>
  </body>
</html>
