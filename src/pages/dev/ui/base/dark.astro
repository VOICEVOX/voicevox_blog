---
import Base from "@/layouts/Base.astro";
---

<Base
  title="Base.astro 確認用ページ（ダークモード）"
  description="Base.astroレイアウトの表示確認（ダークモード）"
  noindex={true}
  isDark={true}
>
  <main class="py-3xl">
    <div class="mx-auto max-w-7xl px-md">
      <h1 class="mb-xl text-5xl font-bold">
        Base.astro レイアウト確認（ダークモード）
      </h1>
      <p class="mb-xl text-xl">
        このページはBase.astroレイアウトを使用しています。
      </p>

      <h2
        class="mb-md text-3xl font-extrabold text-neutral-700 dark:text-neutral-300"
      >
        他のモード
      </h2>
      <ul class="mb-md ml-2xl list-outside list-disc">
        <li>
          <a
            href="/dev/ui/base/"
            class="text-link hover:text-link-hover dark:text-link-dark dark:hover:text-link-dark-hover font-bold underline"
          >
            ライトモード
          </a>
        </li>
        <li>
          <a
            href="/dev/ui/base/nemo/"
            class="text-link hover:text-link-hover dark:text-link-dark dark:hover:text-link-dark-hover font-bold underline"
          >
            Nemoモード
          </a>
        </li>
      </ul>

      <h2
        class="mt-lg mb-md text-3xl font-extrabold text-neutral-700 dark:text-neutral-300"
      >
        レイアウト構成要素
      </h2>
      <ul class="mb-md ml-2xl list-outside list-disc">
        <li>Header（画面上部）</li>
        <li>メインコンテンツ（この部分）</li>
        <li>Footer（画面下部に固定）</li>
        <li>Modals（非表示）</li>
      </ul>

      <h2
        class="mt-lg mb-md text-3xl font-extrabold text-neutral-700 dark:text-neutral-300"
      >
        ダミーコンテンツ
      </h2>
      {
        Array.from({ length: 5 }).map(() => (
          <p class="mb-md last:mb-0">
            これはダミーの文章です。Base.astroレイアウトの動作確認のために配置されています。
            フッターが最下部に固定されることを確認してください。
          </p>
        ))
      }
    </div>
  </main>
</Base>
