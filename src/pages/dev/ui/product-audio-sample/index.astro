---
import { characterInfos } from "@/constants/characterInfo";
import AudioSample from "@/pages/product/_AudioSample";
import "@/styles/global.css";

const characterInfo = characterInfos["ずんだもん"];
---

<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="robots" content="noindex, nofollow" />
    <title>AudioSample (product) 確認用ページ</title>
  </head>
  <body>
    <div style="padding: 2rem;">
      <h1 class="mb-6 text-2xl font-bold">
        AudioSample (product) 確認用ページ
      </h1>

      <section class="mb-8">
        <h2 class="mb-4 text-xl font-semibold">サンプルボイスUI</h2>
        <div
          class="inline-block rounded-2xl p-8"
          style={{ backgroundColor: characterInfo.lightColor }}
        >
          <div class="w-50">
            <AudioSample client:load characterInfo={characterInfo} />
          </div>
        </div>
      </section>
    </div>
  </body>
</html>

<style lang="scss" is:global>
  /* NOTE: src/pages/product/_TopContainer.astro の is:global スタイルを dev/ui でも再現するため、必要最小限を複製しています */
</style>
