---
import { characterInfos } from "@/constants/characterInfo";
import { descriptionTypes } from "@/pages/dormitory/[characterId]/_constants";
import TypeButton from "@/pages/dormitory/[characterId]/_TypeButton.astro";
import "@/styles/global.css";

const descriptionNames = {
  profile: "プロフィール",
  calls: "呼び方",
} satisfies Record<(typeof descriptionTypes)[number], string>;

const shikokuMetan = characterInfos.四国めたん;
const zundamon = characterInfos.ずんだもん;
---

<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="robots" content="noindex, nofollow" />
    <title>TypeButton 確認用ページ</title>
  </head>
  <body>
    <div class="p-2xl">
      <h1 class="mb-xl text-2xl font-bold">TypeButton 確認用ページ</h1>

      <section class="mb-2xl">
        <h2 class="mb-md text-xl font-semibold">
          四国めたん（プロフィール選択状態）
        </h2>
        <div class="inline-flex">
          <TypeButton
            characterInfo={shikokuMetan}
            selectedType="profile"
            targetType="profile"
            targetName={descriptionNames.profile}
          />
          <TypeButton
            characterInfo={shikokuMetan}
            selectedType="profile"
            targetType="calls"
            targetName={descriptionNames.calls}
          />
        </div>
      </section>

      <section class="mb-2xl">
        <h2 class="mb-md text-xl font-semibold">
          ずんだもん（呼び方選択状態）
        </h2>
        <div class="inline-flex">
          <TypeButton
            characterInfo={zundamon}
            selectedType="calls"
            targetType="profile"
            targetName={descriptionNames.profile}
          />
          <TypeButton
            characterInfo={zundamon}
            selectedType="calls"
            targetType="calls"
            targetName={descriptionNames.calls}
          />
        </div>
      </section>
    </div>
  </body>
</html>
