---
import { characterInfos } from "@/constants/characterInfo";
import DescriptionTypeSwitch from "@/pages/dormitory/[characterId]/_DescriptionTypeSwitch.astro";
import "@/styles/global.css";

const shikokuMetan = characterInfos.四国めたん;
const zundamon = characterInfos.ずんだもん;
---

<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="robots" content="noindex, nofollow" />
    <title>TypeButton 確認用ページ</title>
  </head>
  <body>
    <div class="p-2xl">
      <h1 class="mb-xl text-2xl font-bold">TypeButton 確認用ページ</h1>

      <section class="mb-2xl">
        <h2 class="mb-md text-xl font-semibold">
          四国めたん（プロフィール選択状態）
        </h2>
        <DescriptionTypeSwitch
          characterInfo={shikokuMetan}
          selectedType="profile"
        />
      </section>

      <section class="mb-2xl">
        <h2 class="mb-md text-xl font-semibold">
          ずんだもん（呼び方選択状態）
        </h2>
        <DescriptionTypeSwitch characterInfo={zundamon} selectedType="calls" />
      </section>
    </div>
  </body>
</html>
