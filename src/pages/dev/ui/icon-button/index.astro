---
import IconButton from "@/components/ui/IconButton/index.astro";
import "@/styles/global.css";
import { faHome, faXmark } from "@fortawesome/free-solid-svg-icons";
import { FontAwesomeIcon } from "@fortawesome/react-fontawesome";
import { ReactIconButtonDemo } from "./_ReactIconButtonDemo.tsx";
---

<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="robots" content="noindex, nofollow" />
    <title>IconButton 確認用ページ</title>
  </head>
  <body>
    <div class="p-2xl">
      <h1 class="mb-xl text-2xl font-bold">IconButton 確認用ページ</h1>

      <section class="mb-2xl">
        <h2 class="mb-md text-xl font-semibold">borderなし</h2>
        <div class="gap-md flex flex-wrap items-center">
          <IconButton size="sm" aria-label="sm">
            <FontAwesomeIcon icon={faHome} />
          </IconButton>
          <IconButton size="md" aria-label="md">
            <FontAwesomeIcon icon={faHome} />
          </IconButton>
          <IconButton size="lg" aria-label="lg">
            <FontAwesomeIcon icon={faHome} />
          </IconButton>
          <IconButton size="xl" aria-label="xl">
            <FontAwesomeIcon icon={faHome} />
          </IconButton>
        </div>
      </section>

      <section class="mb-2xl">
        <h2 class="mb-md text-xl font-semibold">borderあり</h2>
        <div class="gap-md flex flex-wrap items-center">
          <IconButton size="sm" border aria-label="sm border">
            <FontAwesomeIcon icon={faHome} />
          </IconButton>
          <IconButton size="md" border aria-label="md border">
            <FontAwesomeIcon icon={faHome} />
          </IconButton>
          <IconButton size="lg" border aria-label="lg border">
            <FontAwesomeIcon icon={faHome} />
          </IconButton>
          <IconButton size="xl" border aria-label="xl border">
            <FontAwesomeIcon icon={faHome} />
          </IconButton>
        </div>
      </section>

      <section class="mb-2xl">
        <h2 class="mb-md text-xl font-semibold">色</h2>
        <div class="gap-md flex flex-wrap items-center">
          <IconButton
            size="md"
            border
            class="text-neutral-900"
            aria-label="neutral-900"
          >
            <FontAwesomeIcon icon={faXmark} />
          </IconButton>
          <IconButton
            size="md"
            border
            class="text-primary"
            aria-label="primary"
          >
            <FontAwesomeIcon icon={faXmark} />
          </IconButton>
          <IconButton
            size="md"
            border
            class="text-emerald-600"
            aria-label="emerald-600"
          >
            <FontAwesomeIcon icon={faXmark} />
          </IconButton>
          <IconButton
            size="md"
            border
            class="text-sky-600"
            aria-label="sky-600"
          >
            <FontAwesomeIcon icon={faXmark} />
          </IconButton>
          <IconButton
            size="md"
            border
            class="text-rose-600"
            aria-label="rose-600"
          >
            <FontAwesomeIcon icon={faXmark} />
          </IconButton>
        </div>
      </section>

      <section class="mb-2xl">
        <h2 class="mb-md text-xl font-semibold">React</h2>
        <ReactIconButtonDemo client:load />
      </section>
    </div>
  </body>
</html>
