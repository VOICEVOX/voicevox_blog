---
import PlayButton from "@/components/PlayButton/index.astro";
import "@/styles/global.css";

import zundamonAudio1 from "@/assets/talk-audios/zundamon-normal-001.wav";
import zundamonAudio2 from "@/assets/talk-audios/zundamon-normal-002.wav";
import zundamonAudio3 from "@/assets/talk-audios/zundamon-normal-003.wav";
---

<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="robots" content="noindex, nofollow" />
    <title>PlayButton 確認用ページ</title>
  </head>
  <body>
    <div class="p-2xl">
      <h1 class="mb-xl text-2xl font-bold">PlayButton 確認用ページ</h1>

      <section class="mb-2xl">
        <h2 class="mb-md text-xl font-semibold">デフォルト（primary）</h2>
        <div class="flex items-center gap-xs">
          <PlayButton audio={zundamonAudio1} name="ずんだもんサンプル1" />
          <PlayButton audio={zundamonAudio2} name="ずんだもんサンプル2" />
          <PlayButton audio={zundamonAudio3} name="ずんだもんサンプル3" />
        </div>
      </section>

      <section class="mb-2xl">
        <h2 class="mb-md text-xl font-semibold">サイズバリエーション</h2>
        <div class="flex items-center gap-md">
          <div>
            <p class="mb-xs">sm</p>
            <PlayButton audio={zundamonAudio1} name="ずんだもん小" size="sm" />
          </div>
          <div>
            <p class="mb-xs">デフォルト</p>
            <PlayButton audio={zundamonAudio1} name="ずんだもん通常" />
          </div>
          <div>
            <p class="mb-xs">md</p>
            <PlayButton audio={zundamonAudio1} name="ずんだもん中" size="md" />
          </div>
          <div>
            <p class="mb-xs">lg</p>
            <PlayButton audio={zundamonAudio1} name="ずんだもん大" size="lg" />
          </div>
        </div>
      </section>

      <section class="mb-2xl">
        <h2 class="mb-md text-xl font-semibold">カスタムカラー（Nemo用）</h2>
        <div class="flex items-center gap-md">
          <div>
            <p class="mb-xs">女性（ピンク）</p>
            <PlayButton
              audio={zundamonAudio1}
              name="女性ボイス"
              color="#f1736f"
            />
          </div>
          <div>
            <p class="mb-xs">男性（水色）</p>
            <PlayButton
              audio={zundamonAudio1}
              name="男性ボイス"
              color="#6fcef1"
            />
          </div>
        </div>
      </section>
    </div>
  </body>
</html>
