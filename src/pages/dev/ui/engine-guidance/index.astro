---
import EngineGuidanceSection from "@/pages/_EngineGuidanceSection.astro";
import "@/styles/global.css";
---

<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="robots" content="noindex, nofollow" />
    <title>EngineGuidanceSection 確認用ページ</title>
  </head>
  <body>
    <div class="p-8">
      <h1 class="mb-6 text-2xl font-bold">
        EngineGuidanceSection 確認用ページ
      </h1>

      <section class="mb-8">
        <h2 class="mb-4 text-xl font-semibold">デフォルト</h2>
        <EngineGuidanceSection />
      </section>

      <section class="mb-8">
        <h2 class="mb-4 text-xl font-semibold">isDark</h2>
        {/* NOTE: `/song` に合わせて isDark の本文色は親側で白にしています。 */}
        <div data-theme="dark" class="bg-black text-white">
          <EngineGuidanceSection />
        </div>
      </section>
    </div>
  </body>
</html>
