---
import "@/styles/global.css";

import {
  StyleDropdownClosed,
  StyleDropdownOpened,
} from "./_StyleDropdownDemo.tsx";
---

<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="robots" content="noindex, nofollow" />
    <title>StyleDropdown 確認用ページ</title>
  </head>
  <body>
    <div class="p-2xl">
      <h1 class="mb-xl text-2xl font-bold">StyleDropdown 確認用ページ</h1>

      <section class="mb-2xl">
        <h2 class="mb-md text-xl font-semibold">基本表示（閉じた状態）</h2>
        <StyleDropdownClosed
          client:load
          styles={["ノーマル", "あまあま", "ツンツン", "セクシー"]}
        />
      </section>

      <section class="mb-2xl">
        <h2 class="mb-md text-xl font-semibold">開いた状態</h2>
        <StyleDropdownOpened
          client:load
          styles={["ノーマル", "あまあま", "ツンツン", "セクシー"]}
        />
      </section>
    </div>
  </body>
</html>
