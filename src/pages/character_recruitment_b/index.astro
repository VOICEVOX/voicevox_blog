---
import Button from "@/components/ui/Button/index.astro";
import Base from "@/layouts/Base.astro";
import {
  faEnvelope,
  faMicrophone,
  faPaperPlane,
  faPenNib,
  faUser,
  faUserGroup,
  faUsersGear,
} from "@fortawesome/free-solid-svg-icons";
import { FontAwesomeIcon } from "@fortawesome/react-fontawesome";

const formUrl = "https://forms.gle/cgGXtsu8oP4GXGn7A";
const contactMail = "voicevox.info@gmail.com";

const audiences = [
  {
    icon: faUser,
    title: "個人で活動している方",
    body: "ひとりで企画を立てている方も歓迎です。まだ準備の途中でも応募できます。",
  },
  {
    icon: faUserGroup,
    title: "同人・サークルの方",
    body: "チームや少人数の制作グループ、これから運営を始める方も応募できます。",
  },
  {
    icon: faUsersGear,
    title: "法人・事務所の方",
    body: "事業として運営されている方や、所属タレントの企画も応募いただけます。",
  },
];

const steps = [
  {
    number: "01",
    title: "フォームを送る",
    body: "企画と音声サンプルを添えてフォームから送信してください。",
  },
  {
    number: "02",
    title: "ヒホ・広報で審査",
    body: "VOICEVOX 側で内容をしっかり拝見します。",
  },
  {
    number: "03",
    title: "結果のご連絡",
    body: "メールで結果をお返しします。追加で資料をお願いすることもあります。",
  },
];

const preparations = [
  {
    icon: faMicrophone,
    title: "音声サンプル",
    body: "声優統計コーパス・ITAコーパス・外郎売の朗読など。音声提供者がまだ決まっていなくても応募できます。",
  },
  {
    icon: faPenNib,
    title: "キャラクターの情報",
    body: "設定の概要・ビジュアル・利用規約。これから整える段階の計画資料でも問題ありません。",
  },
  {
    icon: faUserGroup,
    title: "運営の情報",
    body: "運営名義・公式サイト・動画やSNSのアカウントなど。お持ちでない項目は「なし」で構いません。",
  },
];

const faqs = [
  {
    q: "まだ活動実績がないキャラクターでも応募できますか？",
    a: "もちろん応募いただけます。これから立ち上げる新規キャラクターの企画も歓迎しています。",
  },
  {
    q: "音声提供者がまだ決まっていません。応募できますか？",
    a: "応募できます。フォームでは「なし」とご記入ください。確保できてからの再応募も可能です。",
  },
  {
    q: "音声提供者が未成年です。応募できますか？",
    a: "保護者の方の同意を得ている場合に応募いただけます。フォーム内でご確認させていただきます。",
  },
  {
    q: "音声提供者が事務所に所属しています。何か必要なものはありますか？",
    a: "VOICEVOX キャラクター付き音源企画への応募について、所属先から事前に許諾を取得してください。",
  },
];
---

<Base
  title="キャラクター募集 | VOICEVOX"
  description="VOICEVOX では新しい仲間になるキャラクターを募集しています。個人・同人・法人どなたでも応募できます。"
>
  <main>
    <section class="bg-primary text-neutral-950">
      <div
        class="py-4xl px-md mx-auto flex max-w-5xl flex-col items-center text-center"
      >
        <p
          class="text-sm font-bold tracking-[0.3em] text-neutral-800 uppercase"
        >
          Character Recruitment
        </p>
        <h1 class="mt-md text-5xl font-extrabold text-neutral-950 md:text-7xl">
          キャラクター募集
        </h1>
        <p class="mt-md max-w-2xl text-xl font-semibold text-neutral-900">
          VOICEVOX の新しい仲間になるキャラクターを募集しています。
        </p>
        <p class="mt-xs max-w-2xl text-base text-neutral-800">
          個人・同人・法人どなたでも応募できます。
          まだ準備の途中でも、相談のつもりで送ってみてください。
        </p>
        <div class="mt-xl">
          <Button
            href={formUrl}
            target="_blank"
            rel="noreferrer"
            kind="solid"
            tone="white"
            shape="pill"
            size="xl"
          >
            <span slot="icon">
              <FontAwesomeIcon icon={faPaperPlane} />
            </span>
            応募フォームを開く
          </Button>
        </div>
      </div>
    </section>

    <section class="py-3xl">
      <div class="px-md mx-auto flex max-w-5xl flex-col">
        <h2 class="mb-xl text-3xl font-bold text-neutral-950">
          こんな方からの応募をお待ちしています
        </h2>
        <div class="gap-md grid grid-cols-1 md:grid-cols-3">
          {
            audiences.map((item) => (
              <div class="p-lg rounded-2xl border border-neutral-200 bg-white">
                <span class="bg-primary flex h-12 w-12 items-center justify-center rounded-full text-xl text-neutral-950">
                  <FontAwesomeIcon icon={item.icon} />
                </span>
                <h3 class="mt-md text-xl font-bold text-neutral-950">
                  {item.title}
                </h3>
                <p class="mt-xs text-sm text-neutral-700">{item.body}</p>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <section class="py-3xl bg-neutral-50">
      <div class="px-md mx-auto flex max-w-5xl flex-col">
        <h2 class="mb-xl text-3xl font-bold text-neutral-950">応募の流れ</h2>
        <ol class="gap-md grid grid-cols-1 md:grid-cols-3">
          {
            steps.map((step) => (
              <li class="p-lg rounded-2xl border border-neutral-200 bg-white">
                <span class="text-primary text-3xl font-extrabold">
                  {step.number}
                </span>
                <h3 class="mt-xs text-xl font-bold text-neutral-950">
                  {step.title}
                </h3>
                <p class="mt-xs text-sm text-neutral-700">{step.body}</p>
              </li>
            ))
          }
        </ol>
      </div>
    </section>

    <section class="py-3xl">
      <div class="px-md mx-auto flex max-w-5xl flex-col">
        <h2 class="mb-xl text-3xl font-bold text-neutral-950">
          準備しておきたいもの
        </h2>
        <p class="mb-lg text-base text-neutral-700">
          全部そろっていなくても応募できます。
          フォーム内で聞かれる主な項目はこの3つです。
        </p>
        <div class="gap-md grid grid-cols-1 md:grid-cols-3">
          {
            preparations.map((item) => (
              <div class="p-lg gap-md flex flex-col rounded-2xl border border-neutral-200 bg-white">
                <span class="bg-primary flex h-12 w-12 items-center justify-center rounded-full text-xl text-neutral-950">
                  <FontAwesomeIcon icon={item.icon} />
                </span>
                <div>
                  <h3 class="text-xl font-bold text-neutral-950">
                    {item.title}
                  </h3>
                  <p class="mt-xs text-sm text-neutral-700">{item.body}</p>
                </div>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <section class="py-3xl bg-neutral-50">
      <div class="px-md mx-auto flex max-w-3xl flex-col">
        <h2 class="mb-xl text-3xl font-bold text-neutral-950">
          よくあるご質問
        </h2>
        <div class="gap-xs flex flex-col">
          {
            faqs.map((faq) => (
              <details class="vv-status-layer rounded-lg border border-neutral-200 bg-white">
                <summary class="px-md py-md cursor-pointer list-none text-base font-bold text-neutral-950">
                  {faq.q}
                </summary>
                <p class="px-md pb-md text-sm text-neutral-700">{faq.a}</p>
              </details>
            ))
          }
        </div>
      </div>
    </section>

    <section class="py-4xl bg-primary text-neutral-950">
      <div
        class="px-md mx-auto flex max-w-3xl flex-col items-center text-center"
      >
        <h2 class="text-3xl font-extrabold text-neutral-950 md:text-4xl">
          あなたのキャラクターを、ぜひ。
        </h2>
        <p class="mt-md text-base text-neutral-900">
          応募内容はヒホと広報で拝見します。フォームでお預かりした情報は、
          ご返信や確認に必要な範囲だけで利用します。
        </p>
        <div class="mt-xl">
          <Button
            href={formUrl}
            target="_blank"
            rel="noreferrer"
            kind="solid"
            tone="white"
            shape="pill"
            size="xl"
          >
            <span slot="icon">
              <FontAwesomeIcon icon={faPaperPlane} />
            </span>
            応募フォームを開く
          </Button>
        </div>
        <p class="mt-xl text-sm text-neutral-800">
          お問い合わせは&nbsp;<a href={`mailto:${contactMail}`} class="vv-link">
            <FontAwesomeIcon icon={faEnvelope} />&nbsp;{contactMail}
          </a>&nbsp;まで。
        </p>
      </div>
    </section>
  </main>
</Base>
