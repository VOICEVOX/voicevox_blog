---
interface Props {
  class?: string;
  isDark?: boolean; // Nemoやソングのページかどうか
}

import FontAwesomeIcon from "@/components/FontAwesomeIcon.astro";
import { faGithub } from "@fortawesome/free-brands-svg-icons";

const { class: className, isDark } = Astro.props;
---

<section class="py-12">
  <div class={`${className} max-w-4xl mx-auto px-4 flex flex-col`}>
    <h2
      id="oss"
      class="pt-[calc(3.25rem+1rem)] -mt-[calc(3.25rem+1rem)] text-3xl font-bold mb-6"
    >
      <a
        href="#oss"
        class={isDark
          ? "text-white dark:text-white"
          : "text-black dark:text-black"}
      >
        開発に参加するには
      </a>
    </h2>
    <p class="text-xl">
      VOICEVOX は OSS（オープンソース・ソフトウェア）版 VOICEVOX
      をもとに構築されています。
    </p>
    <p class="text-xl">
      追加したい・改善したい機能があれば、ぜひ開発にご参加ください。
    </p>
    <p class="text-xl">
      製品版と OSS 版の違いやモジュール構成は&nbsp;<a
        href="https://github.com/VOICEVOX/voicevox/blob/main/docs/%E5%85%A8%E4%BD%93%E6%A7%8B%E6%88%90.md"
        target="_blank"
        rel="noreferrer"
        class="font-bold underline text-[rgb(48,100,57)] hover:text-[rgb(38,80,47)] dark:text-[rgb(165,212,173)] dark:hover:text-[rgb(185,232,193)]"
        >VOICEVOX の全体構成</a
      >&nbsp;をご参照ください。
    </p>
    <p class="text-xl">
      エディター部分は Electron + Vue 、エンジン部分は Python 、コア部分は Rust
      です。
    </p>
    <div class="flex flex-wrap gap-2 mt-3">
      <a
        class="inline-flex items-center gap-2 border rounded px-4 py-2 text-sm border-gray-400 dark:border-gray-600 bg-white dark:bg-gray-800 text-black dark:text-white hover:bg-gray-50 dark:hover:bg-gray-700"
        href="https://github.com/VOICEVOX/voicevox"
        target="_blank"
        rel="noreferrer"
      >
        <span class="inline-flex items-center">
          <FontAwesomeIcon icon={faGithub} />
        </span>
        <span>VOICEVOX エディター</span>
      </a>
      <a
        class="inline-flex items-center gap-2 border rounded px-4 py-2 text-sm border-gray-400 dark:border-gray-600 bg-white dark:bg-gray-800 text-black dark:text-white hover:bg-gray-50 dark:hover:bg-gray-700"
        href="https://github.com/VOICEVOX/voicevox_engine"
        target="_blank"
        rel="noreferrer"
      >
        <span class="inline-flex items-center">
          <FontAwesomeIcon icon={faGithub} />
        </span>
        <span>VOICEVOX エンジン</span>
      </a>
      <a
        class="inline-flex items-center gap-2 border rounded px-4 py-2 text-sm border-gray-400 dark:border-gray-600 bg-white dark:bg-gray-800 text-black dark:text-white hover:bg-gray-50 dark:hover:bg-gray-700"
        href="https://github.com/VOICEVOX/voicevox_core"
        target="_blank"
        rel="noreferrer"
      >
        <span class="inline-flex items-center">
          <FontAwesomeIcon icon={faGithub} />
        </span>
        <span>VOICEVOX コア</span>
      </a>
    </div>
  </div>
</section>
