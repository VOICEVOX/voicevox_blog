---
import type { CharacterInfo } from "@/constants/type";
import { getProductPageUrl } from "@/constants/url";
import { withBaseUrl } from "@/helper";
import { showLibraryTermIntroModalCharacterKeyAttr } from "@/store";
// NOTE: PlayButtonのため
import { Image } from "astro:assets";
import AudioSample from "./_AudioSample";

interface Props {
  characterInfo: CharacterInfo;
}

const { characterInfo } = Astro.props;
const characterKey = characterInfo.key;
---

<div class="box-border w-full flex-none p-3 md:w-1/2 lg:w-1/3">
  <div class="rounded-xl bg-white shadow-lg ring-1 ring-black/5">
    <a
      href={withBaseUrl(getProductPageUrl(characterInfo))}
      class="block overflow-hidden rounded-t-xl"
    >
      <Image
        class="mx-auto block"
        src={characterInfo.toppageBustupImage ?? characterInfo.bustupImage}
        alt={characterInfo.name}
        width="320"
        densities={[1, 1.5, 2]}
        style={{ objectFit: "contain" }}
      />
    </a>
    <div class="p-6 text-center">
      <h3 class="text-2xl leading-[27px] font-extrabold">
        <a
          href={withBaseUrl(getProductPageUrl(characterInfo))}
          class="text-current"
        >
          {characterInfo.name}
        </a>
      </h3>
      <p class="mt-0 mb-6 text-xl leading-[25px]">
        {characterInfo.voiceFeature ? characterInfo.voiceFeature : "（準備中）"}
      </p>
      {
        characterInfo.releaseDate != undefined && (
          <p class="-mt-4 py-0 font-semibold text-red-600">Coming Soon</p>
        )
      }
      {
        characterInfo.talkVoiceAudios.length > 0 && (
          <AudioSample
            client:visible
            audioSamples={characterInfo.talkVoiceAudios}
            characterName={characterInfo.name}
          />
        )
      }
      <div class="-mx-6 pt-3">
        <button
          {...{ [showLibraryTermIntroModalCharacterKeyAttr]: characterKey }}
          class="inline-flex h-10 items-center justify-center rounded-full border border-gray-300 bg-white px-5 text-base font-medium shadow-sm hover:bg-neutral-50"
          type="button"
        >
          <span>{characterInfo.name} 利用規約</span>
        </button>
      </div>
    </div>
  </div>
</div>

<style lang="scss" is:global>
  .audio-sample {
    .audio-sample-pair {
      display: flex;
      justify-content: center;
      align-items: center;
      flex-wrap: wrap;
      gap: 3px 10px;

      padding-top: 0.25rem;
      padding-bottom: 0.25rem;

      .audio-sample-label {
        width: 100px;
        // @include from($tablet) {
        //   text-align: right !important;
        // }
      }
      .audio-sample-content {
        display: flex;
        gap: 3px;
      }
    }
  }
</style>
