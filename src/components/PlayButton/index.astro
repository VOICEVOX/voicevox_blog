---
import PlayButton from "./PlayButton";

interface Props {
  audio: string;
  name: string;
  color?: string;
  size?: "sm" | "md" | "lg";
  class?: string;
}

const { audio, name, color, size, class: className } = Astro.props;
---

<PlayButton
  client:visible
  url={audio}
  name={name}
  color={color}
  size={size}
  className={className}
/>
